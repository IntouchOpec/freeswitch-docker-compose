<include>
  <!-- ใส่ Public IP ของคุณ -->
  <X-PRE-PROCESS cmd="set" data="external_rtp_ip=192.168.1.107"/>
  <X-PRE-PROCESS cmd="set" data="external_sip_ip=192.168.1.107"/>
  <X-PRE-PROCESS cmd="set" data="domain=192.168.1.107"/>
  <X-PRE-PROCESS cmd="set" data="domain_name=$${domain}"/>

  <!-- Default password for all extensions (override per user) -->
  <X-PRE-PROCESS cmd="set" data="default_password=1234"/>

  <!-- SIP port -->
  <X-PRE-PROCESS cmd="set" data="internal_sip_port=5060"/>
  <X-PRE-PROCESS cmd="set" data="internal_tls_port=5061"/>

  <!-- RTP port range -->
  <X-PRE-PROCESS cmd="set" data="rtp_start_port=16384"/>
  <X-PRE-PROCESS cmd="set" data="rtp_end_port=32768"/>

  <!-- Hold music -->
  <X-PRE-PROCESS cmd="set" data="hold_music=local_stream://moh"/>

  <!-- Media timeouts (seconds) -->
  <X-PRE-PROCESS cmd="set" data="media_timeout=300"/>
  <X-PRE-PROCESS cmd="set" data="media_hold_timeout=1800"/>

  <!-- Outbound caller ID defaults (referenced in directory user XMLs) -->
  <X-PRE-PROCESS cmd="set" data="outbound_caller_name=FreeSWITCH"/>
  <X-PRE-PROCESS cmd="set" data="outbound_caller_id=0000000000"/>
</include>
