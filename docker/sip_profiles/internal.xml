<profile name="internal">
  <domains>
    <domain name="all" alias="true" parse="true"/>
  </domains>
  <settings>
    <param name="username" value="FreeSWITCH"/>
    <param name="realm" value="$${domain}"/>
    <param name="sip-ip" value="0.0.0.0"/>
    <param name="ext-sip-ip" value="$${external_sip_ip}"/>
    <!-- Port 5080: internal profile for phones/extensions (image default; 5060 is external/trunks) -->
    <param name="sip-port" value="5080"/>
    <param name="rtp-ip" value="0.0.0.0"/>
    <param name="ext-rtp-ip" value="$${external_rtp_ip}"/>
    <param name="local-network-acl" value="localnet.auto"/>
    <param name="apply-nat-acl" value="nat.auto"/>
    <param name="auth-calls" value="true"/>
    <param name="auth-all-packets" value="false"/>
    <param name="inbound-codec-prefs" value="OPUS,G722,PCMU,PCMA,G729"/>
    <param name="outbound-codec-prefs" value="OPUS,G722,PCMU,PCMA,G729"/>
    <param name="inbound-late-negotiation" value="true"/>
    <!-- Force RTP through FreeSWITCH — prevents drop after answer -->
    <param name="proxy-media" value="true"/>
    <param name="aggressive-nat-detection" value="false"/>
    <!-- FreeSWITCH owns the session timer: proposes 1800 s, rejects anything
         below 120 s with 422 Session Interval Too Small, handles re-INVITEs -->
    <param name="enable-timer" value="true"/>
    <param name="session-expires" value="1800"/>
    <param name="minimum-session-expires" value="120"/>
    <param name="hold-music" value="$${hold_music}"/>
    <param name="context" value="default"/>
    <param name="dtmf-duration" value="2000"/>
    <!-- Fixed: use media_timeout variables instead of deprecated params -->
    <param name="media-timeout" value="$${media_timeout}"/>
    <param name="media-hold-timeout" value="$${media_hold_timeout}"/>
    <param name="tls" value="false"/>
    <!-- WebSocket transport for browser/WebRTC clients (fixes WSI Error) -->
    <param name="ws-binding"  value=":5066"/>
    <param name="wss-binding" value=":7443"/>
  </settings>
</profile>
