<profile name="external">
  <!-- Port 5060 — accepts phones that register without specifying a port.
       Context is "default" so extension-to-extension calls work exactly
       like the internal profile (port 5080). -->
  <gateways>
    <X-PRE-PROCESS cmd="include" data="external/*.xml"/>
  </gateways>

  <domains>
    <domain name="all" alias="true" parse="true"/>
  </domains>

  <settings>
    <param name="sip-ip" value="0.0.0.0"/>
    <param name="ext-sip-ip" value="$${external_sip_ip}"/>
    <param name="sip-port" value="5060"/>
    <param name="rtp-ip" value="0.0.0.0"/>
    <param name="ext-rtp-ip" value="$${external_rtp_ip}"/>

    <param name="dialplan" value="XML"/>
    <!-- Use default context so 100x extension calls are routed the same
         as phones on the internal profile -->
    <param name="context" value="default"/>

    <!-- auth-calls=false: do NOT challenge in-dialog re-INVITEs from registered phones
         (phones send re-INVITE for session keepalive using their own IP as domain → FS
          directory lookup fails → 13s drop). Registration auth is unaffected. -->
    <param name="auth-calls" value="false"/>
    <param name="auth-all-packets" value="false"/>
    <!-- Normalize registration domain so directory lookup always uses FS domain,
         not the phone's own IP address -->
    <param name="force-register-domain" value="$${domain}"/>
    <param name="force-subscription-domain" value="$${domain}"/>
    <param name="force-register-db-domain" value="$${domain}"/>

    <!-- Explicit codecs — fixes INCOMPATIBLE_DESTINATION -->
    <param name="inbound-codec-prefs" value="OPUS,G722,PCMU,PCMA,G729"/>
    <param name="outbound-codec-prefs" value="OPUS,G722,PCMU,PCMA,G729"/>
    <!-- Late negotiation: accept call first, agree codec after -->
    <param name="inbound-late-negotiation" value="true"/>

    <!-- Force all RTP through FreeSWITCH — correct param names for this version -->
    <param name="inbound-proxy-media" value="true"/>
    <param name="outbound-proxy-media" value="true"/>

    <!-- LAN phones — do NOT rewrite SDP IPs aggressively -->
    <param name="aggressive-nat-detection" value="false"/>

    <!-- Session timer DISABLED: prevents mid-call re-INVITE auth failure (13s drop)
         Phones manage their own session timers independently -->
    <param name="enable-timer" value="false"/>

    <param name="hold-music" value="$${hold_music}"/>
    <param name="dtmf-duration" value="2000"/>
    <param name="rtp-timer-name" value="soft"/>
    <param name="local-network-acl" value="localnet.auto"/>
    <param name="apply-nat-acl" value="nat.auto"/>
    <param name="manage-presence" value="false"/>
    <param name="media-timeout" value="$${media_timeout}"/>
    <param name="media-hold-timeout" value="$${media_hold_timeout}"/>
    <param name="tls" value="false"/>
  </settings>
</profile>
