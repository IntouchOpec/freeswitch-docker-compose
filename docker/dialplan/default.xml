<include>
  <context name="default">

    <!-- ── Local extensions 1000–1009 ──────────────────────────────────── -->
    <extension name="local_extension">
      <condition field="destination_number" expression="^(100[0-9])$">
        <action application="set" data="dialed_extension=$1"/>
        <action application="export" data="dialed_extension=$1"/>
        <!-- proxy_media on BOTH legs: set=A-leg, export=B-leg (profile-level ignored in v1.10.12) -->
        <action application="set" data="proxy_media=true"/>
        <action application="export" data="proxy_media=true"/>
        <!-- Override any small rtp_timeout_sec from image defaults — set=A-leg, export=B-leg -->
        <action application="set" data="rtp_timeout_sec=300"/>
        <action application="export" data="rtp_timeout_sec=300"/>
        <action application="set" data="rtp_hold_timeout_sec=1800"/>
        <action application="export" data="rtp_hold_timeout_sec=1800"/>
        <action application="set" data="ringback=${us-ring}"/>
        <action application="set" data="call_timeout=30"/>
        <!-- Abort cleanly if callee not registered instead of silent 480 -->
        <action application="set" data="continue_on_fail=USER_NOT_REGISTERED,NO_ROUTE_DESTINATION,SUBSCRIBER_ABSENT"/>
        <!-- Try user/ (directory lookup) first; fall back to sofia/internal directly -->
        <action application="bridge" data="user/$1@$${domain}"/>
        <!-- Fallback: direct profile bridge in case directory lookup returns empty contact -->
        <action application="bridge" data="sofia/internal/$1@$${domain}"/>
        <action application="respond" data="480 User Not Registered"/>
      </condition>
    </extension>

    <!-- ── Echo / loopback test (9196) ────────────────────────────────── -->
    <extension name="echo">
      <condition field="destination_number" expression="^9196$">
        <action application="answer"/>
        <action application="echo"/>
      </condition>
    </extension>

    <!-- ── Milliwatt tone test (9197) ─────────────────────────────────── -->
    <extension name="milliwatt">
      <condition field="destination_number" expression="^9197$">
        <action application="answer"/>
        <action application="playback" data="tone_stream://%(251,0,1004)"/>
      </condition>
    </extension>

    <!-- ── Voicemail check (*98) ───────────────────────────────────────── -->
    <extension name="voicemail_check">
      <condition field="destination_number" expression="^\*98$">
        <action application="answer"/>
        <action application="voicemail" data="check default $${domain} ${caller_id_number}"/>
      </condition>
    </extension>

  </context>
</include>
